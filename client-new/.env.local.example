# Retell voice AI
RETELLAI_API_KEY=your-retell-secret-key
NEXT_PUBLIC_RETELL_AGENT_ID=your-retell-agent-id

# Optional: dev Retell agent wired to your LOCAL backend. When set, local dev
# probes the dev backend's /ping and dials this agent if it's reachable,
# otherwise falls back to NEXT_PUBLIC_RETELL_AGENT_ID. Ignored in prod builds.
NEXT_PUBLIC_RETELL_AGENT_ID_DEV=

# Optional: dev backend base URL probed to decide dev-vs-prod agent.
# Defaults to the Makefile's ngrok tunnel when unset.
NEXT_PUBLIC_DEV_API_URL=https://conversational.ngrok.app

# Optional: lock CORS origin in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
